# ============================================================
# Smart Irrigation Advisor – Environment Variable Template
# ============================================================
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ============================================================

# ---- Google Cloud Project ----
GCP_PROJECT_ID=your-gcp-project-id
GCP_REGION=us-central1

# ---- BigQuery ----
BIGQUERY_DATASET=smart_irrigation
BIGQUERY_LOCATION=US

# ---- Pub/Sub ----
PUBSUB_TOPIC_ID=irrigation-alerts

# ---- SendGrid ----
# Create a free SendGrid account at https://sendgrid.com
# Generate an API key with "Mail Send" permissions
SENDGRID_API_KEY=SG.xxxxxxxxxxxxxxxxxxxx
ALERT_FROM_EMAIL=[EMAIL_ADDRESS]

# ---- Alert Thresholds ----
# Minimum urgency level to trigger email alerts
# Options: CRITICAL | HIGH | MODERATE | NONE
ALERT_MIN_URGENCY=HIGH

# ---- Weather Data ----
# Number of days of historical data to fetch from NASA POWER
WEATHER_LOOKBACK_DAYS=7

# ---- Cloud Functions ----
# CORS allowed origin for the get_recommendations API
CORS_ORIGIN=*

# ---- (Optional) Application Credentials ----
# If running locally, point to your service account key JSON file
# For Cloud Functions, use the runtime service account instead
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account-key.json
